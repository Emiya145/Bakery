# Django Settings
SECRET_KEY=your-secret-key-here-change-this-in-production
DEBUG=True
DJANGO_SETTINGS_MODULE=bakery.settings.dev

# Database Configuration (Production - MySQL)
DB_NAME=yourusername$bakery
DB_USER=yourusername
DB_PASSWORD=your-mysql-password
DB_HOST=yourusername.mysql.pythonanywhere-services.com

# Email Configuration (for alerts and notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@yourbakery.com
INVENTORY_ALERT_EMAIL=manager@yourbakery.com

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here
